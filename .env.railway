# Railway Environment Configuration for PequeRoku
# Generated from code analysis of source/ directory

# ============================================================================
# Database Configuration (Required)
# ============================================================================
DB_NAME=pequeroku
DB_USER=railway_user
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# ============================================================================
# Django Configuration
# ============================================================================
SECRET_KEY=
DEBUG=false
DJANGO_SETTINGS_MODULE=pequeroku.settings
ALLOWED_HOSTS=*
INTERNAL_HOSTS=web,localhost,127.0.0.1
HTTP_PORT=8000
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_PASSWORD=
DJANGO_SUPERUSER_EMAIL=admin@example.com

# ============================================================================
# Django Logging
# ============================================================================
LOG_LEVEL=WARNING
TIME_ZONE=Asia/Amman

# ============================================================================
# Redis Configuration
# ============================================================================
REDIS_URL=redis://localhost:6379/1
REDIS_PREFIX=web_service:

# ============================================================================
# Background Task Configuration
# ============================================================================
RECONCILE_INTERVAL=30
PREWARM_INTERVAL=30
RUN_WORKER_INTERVAL=5
REAP_INTERVAL=30

# ============================================================================
# Gunicorn Configuration
# ============================================================================
WORKERS=4
PORT=8000

# ============================================================================
# API Rate Limiting
# ============================================================================
PLATFORM_API_THROTTLE_RATE=120/min

# ============================================================================
# AI/LLM Provider API Keys (Leave empty - set in Railway dashboard)
# ============================================================================
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPEN_ROUTER_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
OPENAI_LIKE_API_KEY=

# ============================================================================
# AI Model Configuration
# ============================================================================
# These are stored in Django Config table (internal_config.models.Config)
# Set via Django admin or management command
# openai_api_key
# openai_api_url (defaults to https://api.openai.com/v1)
# openai_model (defaults to gpt-4o)
# token_input_price
# token_output_price

# ============================================================================
# Application Behavior Configuration
# ============================================================================
START_FROM_LATEST=true
MAX_CONCURRENT_TASKS=2

# ============================================================================
# VM Service Configuration (if deploying separately)
# ============================================================================
# VM_SSH_USER=root
# VM_SSH_PRIVKEY=/root/.ssh/id_vm_pequeroku
# VM_BASE_IMAGE=debian12-golden.qcow2
# VM_TIMEOUT_BOOT_S=600
# VM_USE_CLOUD_INIT=true
# NODE_NAME=railway-node
# AUTH_TOKEN=
# VM_TASKSET_CPUS=

# ============================================================================
# MCP Service Configuration (if deploying separately)
# ============================================================================
# PEQUEROKU_API_URL=http://web:8000
# PEQUEROKU_MCP_HOST=0.0.0.0
# PEQUEROKU_MCP_PORT=8002
