# ============================================================
# SHAHEEN-YS — Environment Variables
#
# Usage:
#   cp .env.example .env
#   # Edit .env and fill in your real values
#   docker compose up -d
#
# NEVER commit .env to version control.
# ============================================================

# ── Django ───────────────────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=shaheen-ys-dev-secret-key-not-for-production
DEBUG=0
ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com

# Django ASGI module (do not change unless you rename the project)
DJANGO_MODULE=pequeroku

# Gunicorn worker count (rule of thumb: 2 × CPU cores + 1)
GUNICORN_WORKERS=4

# First-run superuser (created automatically on `docker compose up`)
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@shaheen.local
DJANGO_SUPERUSER_PASSWORD=change-me-too

# ── PostgreSQL ────────────────────────────────────────────────
DB_NAME=shaheen
DB_USER=shaheen
DB_PASSWORD=shaheensecret
# DB_HOST is always "db" inside Docker; do not change.
# DB_HOST=db
# DB_PORT=5432

# Gitea uses its own database inside the shared Postgres instance
GITEA_DB_NAME=gitea

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Celery ────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
CELERY_CONCURRENCY=4

# ── Nginx / Ports ─────────────────────────────────────────────
HTTP_PORT=8080
# SSH port for Gitea git operations (git clone git@host:repo)
GITEA_SSH_PORT=222

# ── Gitea ─────────────────────────────────────────────────────
GITEA_ROOT_URL=http://localhost/gitea/

# ── OpenHands ─────────────────────────────────────────────────
OPENHANDS_LLM_MODEL=gpt-4o
OPENHANDS_HOSTNAME=localhost

# ── OpenAI / LLM keys ─────────────────────────────────────────
# Used by Django AI agent and OpenHands
OPENAI_API_KEY=
